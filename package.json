{
	"name": "explorer-overhaul",
	"version": "0.0.1",
	"files": [
		"src"
	],
	"main": "./src/index.js",
	"type": "module",
	"activationEvents": [],
	"contributes": {
		"commands": [
			{
				"command": "explorer-overhaul.replaceInFolderWithWorkbenchStateFolder",
				"title": "Replace in Folder..."
			},
			{
				"command": "explorer-overhaul.replaceInFolderWithWorkbenchStateWorkspace",
				"title": "Replace in Folder..."
			}
		],
		"menus": {
			"commandPalette": [
				{
					"when": "false",
					"command": "explorer-overhaul.replaceInFolderWithWorkbenchStateFolder"
				},
				{
					"when": "false",
					"command": "explorer-overhaul.replaceInFolderWithWorkbenchStateWorkspace"
				}
			],
			"explorer/context": [
				{
					"when": "explorerResourceIsFolder && workbenchState === 'folder'",
					"group": "4_search@20",
					"command": "explorer-overhaul.replaceInFolderWithWorkbenchStateFolder"
				},
				{
					"when": "explorerResourceIsFolder && workbenchState === 'workspace'",
					"group": "4_search@20",
					"command": "explorer-overhaul.replaceInFolderWithWorkbenchStateWorkspace"
				}
			]
		}
	},
	"scripts": {
		"test": "eslint && tsc",
		"build": "vsce package --allow-missing-repository --skip-license"
	},
	"devDependencies": {
		"@koffeine/eslint-config": "^48.8.0",
		"@types/node": "^24.12.2",
		"@types/punycode": "^2.1.4",
		"@types/vscode": "^1.118.0",
		"@vscode/vsce": "^3.9.1",
		"eslint": "^10.3.0",
		"globals": "^17.6.0",
		"typescript": "^6.0.3"
	},
	"engines": {
		"vscode": "^1.118.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "24"
		}
	}
}
